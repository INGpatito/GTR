# ── PostgreSQL Connection ───────────────
DB_HOST=192.168.100.61
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=parking_gtr

# ── Security ────────────────────────────
# Debe ser idéntico al JWT_SECRET del backend Node.js (backend/.env)
JWT_SECRET=your_jwt_secret_here
ADMIN_UNLOCK_PASS=admin123

# ── External APIs ───────────────────────
CARSXE_API_KEY=your_carsxe_key_here

# ── EmailJS (Optional) ─────────────────
# EMAILJS_SERVICE_ID=service_xxx
# EMAILJS_TEMPLATE_ID=template_xxx
# EMAILJS_USER_ID=xxx
# EMAILJS_ACCESS_TOKEN=xxx
