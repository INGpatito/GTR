# ── PostgreSQL ──────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=parking_gtr

# ── Server ──────────────────────────────
PORT=3000

# ── CORS (comma-separated origins) ─────
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5500,http://127.0.0.1:5500,https://papoys.me

# ── Security ────────────────────────────
# API key required for admin endpoints (GET/PATCH /api/reservations)
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=your_admin_api_key_here
